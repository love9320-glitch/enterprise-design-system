{
  "name": "@love9320-glitch/design-system",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check:rules": "node scripts/check-rules.mjs",
    "check:render": "npx esbuild scripts/smoke-render.jsx --bundle --format=cjs --jsx=automatic --platform=node --outfile=node_modules/.cache/smoke-render.cjs --log-level=error && node node_modules/.cache/smoke-render.cjs",
    "check:types": "tsc --noEmit",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:css": "tailwindcss -c tailwind.config.js -i ./src/index.css -o ./dist-lib/styles.css --minify",
    "build:preset": "npx esbuild tailwind.preset.js --bundle --format=esm --platform=neutral --outfile=dist-lib/tailwind-preset.mjs --log-level=error && npx esbuild tailwind.preset.js --bundle --format=cjs --platform=neutral --outfile=dist-lib/tailwind-preset.cjs --log-level=error",
    "build:package": "npm run build:lib && npm run build:css && npm run build:preset",
    "prepublishOnly": "npm run check:types && npm run build:package"
  },
  "dependencies": {
    "lucide-react": "^1.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "@tiptap/core": "^3.27.0",
    "@tiptap/extension-color": "^3.27.0",
    "@tiptap/extension-highlight": "^3.27.0",
    "@tiptap/extension-image": "^3.27.0",
    "@tiptap/extension-link": "^3.27.0",
    "@tiptap/extension-table": "^3.27.0",
    "@tiptap/extension-table-cell": "^3.27.0",
    "@tiptap/extension-table-header": "^3.27.0",
    "@tiptap/extension-table-row": "^3.27.0",
    "@tiptap/extension-text-align": "^3.27.0",
    "@tiptap/extension-text-style": "^3.27.0",
    "@tiptap/extension-underline": "^3.27.0",
    "@tiptap/pm": "^3.27.0",
    "@tiptap/react": "^3.27.0",
    "@tiptap/starter-kit": "^3.27.0"
  },
  "license": "ATS",
  "description": "코드↔Figma 동기화 디자인 시스템 — 토큰 기반 React 컴포넌트 라이브러리",
  "repository": {
    "type": "git",
    "url": "https://github.com/love9320-glitch/enterprise-design-system.git"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist-lib"
  ],
  "main": "./dist-lib/index.js",
  "module": "./dist-lib/index.js",
  "types": "./dist-lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist-lib/index.d.ts",
      "import": "./dist-lib/index.js"
    },
    "./editor": {
      "types": "./dist-lib/editor.d.ts",
      "import": "./dist-lib/editor.js"
    },
    "./tokens": {
      "types": "./dist-lib/tokens/index.d.ts",
      "import": "./dist-lib/tokens.js"
    },
    "./preset": {
      "import": "./dist-lib/tailwind-preset.mjs",
      "require": "./dist-lib/tailwind-preset.cjs"
    },
    "./styles.css": "./dist-lib/styles.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@tiptap/core": "^3.27.0",
    "@tiptap/extension-color": "^3.27.0",
    "@tiptap/extension-highlight": "^3.27.0",
    "@tiptap/extension-image": "^3.27.0",
    "@tiptap/extension-link": "^3.27.0",
    "@tiptap/extension-table": "^3.27.0",
    "@tiptap/extension-table-cell": "^3.27.0",
    "@tiptap/extension-table-header": "^3.27.0",
    "@tiptap/extension-table-row": "^3.27.0",
    "@tiptap/extension-text-align": "^3.27.0",
    "@tiptap/extension-text-style": "^3.27.0",
    "@tiptap/extension-underline": "^3.27.0",
    "@tiptap/pm": "^3.27.0",
    "@tiptap/react": "^3.27.0",
    "@tiptap/starter-kit": "^3.27.0"
  },
  "peerDependenciesMeta": {
    "@tiptap/core": {
      "optional": true
    },
    "@tiptap/extension-color": {
      "optional": true
    },
    "@tiptap/extension-highlight": {
      "optional": true
    },
    "@tiptap/extension-image": {
      "optional": true
    },
    "@tiptap/extension-link": {
      "optional": true
    },
    "@tiptap/extension-table": {
      "optional": true
    },
    "@tiptap/extension-table-cell": {
      "optional": true
    },
    "@tiptap/extension-table-header": {
      "optional": true
    },
    "@tiptap/extension-table-row": {
      "optional": true
    },
    "@tiptap/extension-text-align": {
      "optional": true
    },
    "@tiptap/extension-text-style": {
      "optional": true
    },
    "@tiptap/extension-underline": {
      "optional": true
    },
    "@tiptap/pm": {
      "optional": true
    },
    "@tiptap/react": {
      "optional": true
    },
    "@tiptap/starter-kit": {
      "optional": true
    }
  }
}
